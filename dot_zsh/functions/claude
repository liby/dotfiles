# claude — mode-aware launcher wrapping the claude binary.
#
# claude [args...]                       Launch in the current mode.
# claude --switch-mode [args...]         Interactive picker to switch mode, then launch.
# claude --api-model <model> [args...]   Force API mode for this call and override ANTHROPIC_MODEL.

emulate -L zsh

local pick=0
local api_model=
while (( $# )); do
  case $1 in
    --switch-mode)
      pick=1
      shift
      ;;
    --api-model)
      if (( $# < 2 )) || [[ -z $2 || $2 == -* ]]; then
        print -u2 "claude: --api-model requires a model name"
        return 2
      fi
      api_model=$2
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/claude-code"
local mode_file="$config_dir/mode"
local env_file="$config_dir/.env"

local mode=sub
[[ -f $mode_file ]] && mode=$(< $mode_file)
# --api-model implies API mode (the only mode it works in), single-invocation override.
[[ -n $api_model ]] && mode=api

if (( pick )); then
  [[ -t 0 && -t 1 ]] || { print -u2 "claude: --switch-mode requires an interactive terminal"; return 1 }

  local selected=1
  [[ $mode == api ]] && selected=0

  local cursor=$selected
  local -a labels=(API Subscription) modes=(api sub)
  local key seq first=1
  local teardown=$'\e[2A\e[J\e[?25h'
  local i marker line

  print -n '\e[?25l'

  while true; do
    (( first )) || print -n '\e[2A'
    first=0
    for i in 0 1; do
      (( i == selected )) && marker='●' || marker='○'
      line="  $marker ${labels[i+1]}"
      if (( i == cursor )); then
        print -rn -- $'\e[48;5;237m'"$line"$'\e[K\e[0m'
      else
        print -rn -- "$line"$'\e[K'
      fi
      print
    done

    read -rsk1 key
    case $key in
      $'\e')
        seq=; read -rsk1 -t 0.05 seq 2>/dev/null
        if [[ -z $seq ]]; then
          print -n $teardown
          return 1
        fi
        seq=; read -rsk1 -t 0.05 seq 2>/dev/null
        [[ $seq == [AB] ]] && (( cursor ^= 1 ))
        ;;
      ' '|$'\n')
        selected=$cursor
        break
        ;;
      $'\x03')
        print -n $teardown
        return 130
        ;;
    esac
  done

  print -n $teardown

  mode=$modes[selected+1]
  print -n $mode > $mode_file
fi

# Subshell + exec: env vars don't leak into the parent shell.
if [[ $mode == api ]]; then
  [[ -f $env_file ]] || { print -u2 "claude: $env_file not found"; return 1 }
  (
    set -a
    source "$env_file" || exit 2
    [[ -n $api_model ]] && ANTHROPIC_MODEL=$api_model
    exec command claude "$@"
  )
  local rc=$?
  (( rc == 2 )) && { print -u2 "claude: failed to source $env_file"; return 1 }
  return $rc
else
  command claude "$@"
fi
