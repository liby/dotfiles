{{- if eq .chezmoi.os "darwin" -}}
#!/bin/sh
# Managed by chezmoi — source: run_onchange_after_darwin-link-rtk-config.sh.tmpl
#
# rtk on macOS hardcodes its config path to
#   ~/Library/Application Support/rtk/config.toml
# (Rust dirs crate; no XDG / RTK_CONFIG / env override — verified empirically).
# Symlink that path to the chezmoi-managed XDG-style file so the real config
# lives at ~/.config/rtk/config.toml, and the space-in-path permission nag
# (rtk-ai/rtk#1858) goes away. On Linux rtk uses ~/.config/rtk natively, so this
# script is darwin-only and renders empty (skipped) elsewhere.
set -eu
src="$HOME/.config/rtk/config.toml"
dst="$HOME/Library/Application Support/rtk/config.toml"
mkdir -p "$(dirname "$dst")"
if [ ! -L "$dst" ] || [ "$(readlink "$dst" 2>/dev/null)" != "$src" ]; then
  rm -f "$dst"
  ln -s "$src" "$dst"
  echo "linked $dst -> $src"
fi
{{- end -}}
