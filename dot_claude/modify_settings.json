{{- /* chezmoi:modify-template */ -}}
{{- /* Partial management of ~/.claude/settings.json. The Claude Code CLI
      writes runtime state into this file (/model and /effort defaults,
      one-time dialog acks, keys added by future CLI versions); a plain
      source file made every unscoped `chezmoi apply` silently revert them.
      Semantics: every top-level key in .chezmoitemplates/claude-settings.json
      is enforced from source (whole subtree replaced); $seeds are written
      only when absent, then owned by the CLI; everything else in the target
      passes through. */ -}}
{{- $managed := includeTemplate "claude-settings.json" . | fromJson -}}
{{- $seeds := `{
  "model": "sonnet",
  "effortLevel": "xhigh"
}` | fromJson -}}
{{- $out := dict -}}
{{- if .chezmoi.stdin -}}{{- $out = fromJson .chezmoi.stdin -}}{{- end -}}
{{- range $k, $v := $managed -}}{{- $out = set $out $k $v -}}{{- end -}}
{{- range $k, $v := $seeds -}}
{{-   if not (hasKey $out $k) -}}{{- $out = set $out $k $v -}}{{- end -}}
{{- end -}}
{{ toPrettyJson $out }}
