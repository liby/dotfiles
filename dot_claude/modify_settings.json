{{- /* chezmoi:modify-template */ -}}
{{- /* Partially manage ~/.claude/settings.json so CLI-written defaults, acks,
      and future keys survive apply. claude-settings.json replaces whole
      top-level subtrees: nested removals apply on render; removing a top-level
      key only stops managing it, so retire it from source and live. Seed
      missing model and effort defaults once; preserve other live keys. */ -}}
{{- $managed := includeTemplate "claude-settings.json" . | fromJson -}}
{{- $seeds := `{
  "model": "sonnet",
  "effortLevel": "xhigh"
}` | fromJson -}}
{{- $out := dict -}}
{{- if .chezmoi.stdin -}}{{- $out = fromJson .chezmoi.stdin -}}{{- end -}}
{{- range $k, $v := $managed -}}{{- $out = set $out $k $v -}}{{- end -}}
{{- range $k, $v := $seeds -}}
{{-   if not (hasKey $out $k) -}}{{- $out = set $out $k $v -}}{{- end -}}
{{- end -}}
{{ toPrettyJson $out }}
