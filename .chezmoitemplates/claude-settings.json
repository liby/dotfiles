{
  "cleanupPeriodDays": 99999,
  "env": {
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-5",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_CFC": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "125000",
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_CODE_RETRY_WATCHDOG": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_EXTRA_USAGE_COMMAND": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "includeGitInstructions": false,
  "disableArtifact": true,
  "disableRemoteControl": true,
  "disableClaudeAiConnectors": true,
  "disableBundledSkills": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Agent",
      "Edit",
      "LSP",
      "mcp__chrome-devtools__*",
      "mcp__ide__*",
      "mcp__plugin_atlassian_atlassian__*",
      "mcp__plugin_context7_context7__*",
      "Read",
      "Skill",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(*.claude/.credentials.json*)",
      "Bash(*.npmrc*)",
      "Bash(*.ssh/id_*)",
      "Bash(*.zprofile*)",
      "Bash(*.zsh_history*)",
      "Bash(*auth.json*)",
      "Bash(*gh auth token*)",
      "Bash(*private-keys-v1.d*)",
      "CronCreate",
      "CronDelete",
      "CronList",
      "DesignSync",
      "Edit(~/.claude/.credentials.json*)",
      "Edit(~/.gnupg/private-keys-v1.d/**)",
      "Edit(~/.ssh/id_*)",
      "Edit(~/.zprofile*)",
      "Edit(~/*/auth.json*)",
      "EnterPlanMode",
      "ExitPlanMode",
      "Glob",
      "Grep",
      "NotebookEdit",
      "PushNotification",
      "Read(**/.env.*.local)",
      "Read(**/.env.local*)",
      "Read(**/.env)",
      "Read(~/.aws/credentials*)",
      "Read(~/.claude/.credentials.json*)",
      "Read(~/.gnupg/private-keys-v1.d/**)",
      "Read(~/.npmrc*)",
      "Read(~/.ssh/id_*)",
      "Read(~/.zsh_history*)",
      "Read(~/*/auth.json*)",
      "RemoteTrigger",
      "ReportFindings"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "excludedCommands": [
      "chezmoi:*",
      "docker:*",
      "git:*"
    ],
    "filesystem": {
      "allowWrite": [
        "{{ output "getconf" "DARWIN_USER_TEMP_DIR" | trim | trimSuffix "/" }}",
        "/private/tmp/.pnpm-store",
        "~/.bun",
        "~/.cache",
        "~/.cargo",
        "~/.local/share/uv",
        "~/.npm",
        "~/.pnpm-store",
        "~/.proto",
        "~/.rustup",
        "~/.snowflake/logs",
        "~/Code/.pnpm",
        "~/Library/Caches"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.claude.com",
        "{{ .private.gitlabHost | trimPrefix "https://" | trimSuffix "/" }}",
        "nodejs.org",
        "{{ .private.npmHost | trimPrefix "https://" | trimSuffix "/" }}",
        "registry.npmjs.org"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.trustd.agent"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.gnupg/S.gpg-agent.ssh"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-bash-policy.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-bash-guard-secrets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-edit-warn-chezmoi.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-bash-scan-secrets.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact-instructions.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Vibing"
    ]
  },
  "alwaysThinkingEnabled": true,
  "autoCompactWindow": 400000,
  "worktree": {
    "baseRef": "head"
  },
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "showTurnDuration": false,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "skipDangerousModePermissionPrompt": true
}
