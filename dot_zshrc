# Must run before anything that references $HOMEBREW_PREFIX.
# Keep the env -u: if both vars are inherited, brew reuses the stale HOMEBREW_PATH, so
# shellenv short-circuits and never adds /opt/homebrew/bin to PATH.
eval "$(env -u HOMEBREW_BREW_FILE -u HOMEBREW_PATH /opt/homebrew/bin/brew shellenv)"

# Homebrew zsh completion path
__BRYAN_HOMEBREW_ZSH_COMPLETION="${HOMEBREW_PREFIX}/share/zsh/site-functions"
__BRYAN_ZSH_COMPLETION_SRC="${HOME}/.zsh/plugins/zsh-completions/src"

# ZSH completions
# https://docs.brew.sh/Shell-Completion#configuring-completions-in-zsh
if (( ! ${fpath[(I)${__BRYAN_HOMEBREW_ZSH_COMPLETION}]} && $+commands[brew] )); then
  fpath+=${__BRYAN_HOMEBREW_ZSH_COMPLETION}
fi
## https://github.com/zsh-users/zsh-completions
[[ -d ${__BRYAN_ZSH_COMPLETION_SRC} ]] && fpath+=${__BRYAN_ZSH_COMPLETION_SRC}
fpath+=$HOME/.zsh/functions
## Initialize the completion system
## This must be done after all fpath modifications
autoload -Uz compinit
# Run the full compinit check once a day
() {
  setopt local_options extendedglob
  if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
    compinit && touch ~/.zcompdump
  else
    compinit -C
  fi
}

# Environment variables
export GPG_PATH="$HOMEBREW_PREFIX/opt/gnupg"
export HOMEBREW_BUNDLE_DUMP_NO_VSCODE=1
export HOMEBREW_NO_ENV_HINTS=1
export ORACLE_ENGINE="browser"
export PROTO_AUTO_INSTALL_HIDE_OUTPUT=1
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"

# PATH configuration
typeset -aU path
() {
  local -a path_dirs=(
    "$HOMEBREW_PREFIX/opt/curl/bin"
    "$HOMEBREW_PREFIX/opt/uv/bin"
    "$HOME/bin"
    "$HOME/.cargo/bin"
    "$HOME/.local/bin"
    "$GPG_PATH/bin"
    "$GPG_PATH/libexec"
  )
  path=($path_dirs $path[@])
}

# Alias Set
alias c='open -a "Visual Studio Code"'
alias cc='claude'
alias ccm='claude --switch-provider'
alias cm='chezmoi'
alias cx='open -a /Applications/ChatGPT.app'
alias hr='herdr'
alias ip="curl ip.sb"
alias ipcn="curl myip.ipip.net"
alias ka='caffeinate -is'
alias la='ls --all'
alias ll='la --long --git --time-style=long-iso --no-user'
alias ls='eza --group-directories-first --hyperlink'
alias lt='ll --tree --level=2 --git-ignore --ignore-glob=.git'
alias python='python3'

# Functions (autoloaded from ~/.zsh/functions/)
autoload -Uz $HOME/.zsh/functions/*(N:t)

# This speeds up pasting w/ autosuggest
# https://github.com/zsh-users/zsh-autosuggestions/issues/238
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish

# Skip per-precmd widget rebinding for faster prompt
ZSH_AUTOSUGGEST_MANUAL_REBIND=""

# Source plugins and configurations
source $HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOME/.zsh/plugins/fsh/fast-syntax-highlighting.plugin.zsh

# Clear stale suggestion after paste (not in plugin defaults)
# https://github.com/zsh-users/zsh-autosuggestions/issues/351
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(bracketed-paste)

# Initialize tools and configurations
(( $+commands[gpg-connect-agent] )) && setup_gpg_ssh &>/dev/null
# Guard on the file, not `orb`: the brew-cask CLI exists before ~/.orbstack/,
# which OrbStack.app only creates on first run.
[[ -r ~/.orbstack/shell/init.zsh ]] && source ~/.orbstack/shell/init.zsh
# Work around moonrepo/proto#1054 until a fixed release is installed.
export PROTO_REPORTER=text
(( $+commands[proto] )) && eval "$(proto activate zsh)"
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
